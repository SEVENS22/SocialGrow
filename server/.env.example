# PayPal Configuration
# Obtenha em: https://developer.paypal.com/

# Sandbox (Teste) - Use para desenvolver/testar
PAYPAL_SANDBOX_CLIENT_ID=seu_sandbox_client_id_aqui
PAYPAL_SANDBOX_CLIENT_SECRET=seu_sandbox_client_secret_aqui

# Production (Produção) - Use quando for ao ar
PAYPAL_LIVE_CLIENT_ID=seu_live_client_id_aqui
PAYPAL_LIVE_CLIENT_SECRET=seu_live_client_secret_aqui

# Escolha qual modo usar: 'sandbox' ou 'live'
PAYPAL_MODE=sandbox

# Seu número WhatsApp para notificações
WHATSAPP_NUMBER=258834592663

# URL do seu site (para redirects)
SITE_URL=http://localhost:3000