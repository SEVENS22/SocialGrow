{
  "version": 2,
  "builds": [
    {
      "src": "/api/**",
      "use": "@vercel/node"
    },
    {
      "src": "/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/server.js"
    },
    {
      "src": "/success",
      "dest": "/server/success.html"
    },
    {
      "src": "/cancel",
      "dest": "/server/cancel.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}